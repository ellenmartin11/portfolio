---
import { siteConfig } from "../config";
const developmentProjects =
  siteConfig.projects?.filter((p) => p.category === "development") ?? [];
const researchProjects =
  siteConfig.projects?.filter((p) => p.category === "research") ?? [];

const hasDevelopment = developmentProjects.length > 0;
const hasResearch = researchProjects.length > 0;

const baseUrl = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
---

{
  (hasDevelopment || hasResearch) && (
    <section id="projects" class="p-8 sm:p-12 md:p-16 lg:p-24">
      <div>
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-16 items-start">
          <div class="lg:col-span-4">
            <h2 class="text-2xl sm:text-3xl md:text-4xl xl:text-5xl font-bold text-gray-900">
              Projects
            </h2>
            <div
              class="w-[75px] h-[5px] mt-2 rounded-full"
              style={`background-color: ${siteConfig.accentColor}`}
            />
          </div>

          <div class="lg:col-span-8 space-y-6">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
              {hasResearch && (
                <a
                  href={`${baseUrl}research`}
                  class="group bg-gray-50 rounded-xl border border-gray-200 p-6 hover:bg-white hover:shadow-xl hover:border-gray-300 transition-all duration-300"
                >
                  <div class="flex items-start justify-between gap-4">
                    <div>
                      <div
                        class="text-sm font-mono"
                        style={{ color: siteConfig.accentColor }}
                      >
                        R{researchProjects.length.toString().padStart(2, "0")}
                      </div>
                      <h3 class="text-lg sm:text-xl font-bold text-gray-900 mt-1">
                        Research / Academic Projects
                      </h3>
                      <p class="text-sm sm:text-base text-gray-600 leading-relaxed mt-2">
                        Psychology and neuroscience work: modelling, experiments, and interpretation.
                      </p>
                    </div>
                    <div class="mt-1 w-10 h-10 rounded-full bg-gray-900 text-white flex items-center justify-center transition-all duration-300 group-hover:bg-gray-700">
                      <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M7 17L17 7M17 7H7M17 7V17" />
                      </svg>
                    </div>
                  </div>
                </a>
              )}

              {hasDevelopment && (
                <a
                  href={`${baseUrl}development`}
                  class="group bg-gray-50 rounded-xl border border-gray-200 p-6 hover:bg-white hover:shadow-xl hover:border-gray-300 transition-all duration-300"
                >
                  <div class="flex items-start justify-between gap-4">
                    <div>
                      <div
                        class="text-sm font-mono"
                        style={{ color: siteConfig.accentColor }}
                      >
                        P{developmentProjects.length.toString().padStart(2, "0")}
                      </div>
                      <h3 class="text-lg sm:text-xl font-bold text-gray-900 mt-1">
                        Data Science / Development Portfolio
                      </h3>
                      <p class="text-sm sm:text-base text-gray-600 leading-relaxed mt-2">
                        Apps and applied ML: products, prototypes, and shipped tools.
                      </p>
                    </div>
                    <div class="mt-1 w-10 h-10 rounded-full bg-gray-900 text-white flex items-center justify-center transition-all duration-300 group-hover:bg-gray-700">
                      <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M7 17L17 7M17 7H7M17 7V17" />
                      </svg>
                    </div>
                  </div>
                </a>
              )}
            </div>
          </div>
        </div>
      </div>
    </section>
  )
}
