---
import { siteConfig } from "../config";
const hasResearch =
  siteConfig.projects?.some((p) => p.category === "research") ?? false;
const hasDevelopment =
  siteConfig.projects?.some((p) => p.category === "development") ?? false;
const hasPublications = siteConfig.publications && siteConfig.publications.length > 0;
const hasExperience = siteConfig.experience && siteConfig.experience.length > 0;
const hasEducation = siteConfig.education && siteConfig.education.length > 0;
const hasAwards = siteConfig.awards && siteConfig.awards.length > 0;
const hasCV = siteConfig.cv && siteConfig.cv.link;

const baseUrl = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
---

<header
  id="header"
  class="fixed top-0 left-0 right-0 z-50 hidden md:block transition-all duration-300"
>
  <nav class="max-w-7xl mx-auto px-8 py-4">
    <ul class="flex items-center gap-8 justify-center">
      <li>
        <a
          href={`${baseUrl}#about`}
          class="text-gray-700 hover:text-black transition-colors font-medium"
        >
          About
        </a>
      </li>
      {
        hasResearch && (
          <li>
            <a
              href={`${baseUrl}research`}
              class="text-gray-700 hover:text-black transition-colors font-medium"
            >
              Research
            </a>
          </li>
        )
      }
      {
        hasDevelopment && (
          <li>
            <a
              href={`${baseUrl}development`}
              class="text-gray-700 hover:text-black transition-colors font-medium"
            >
              Data Science
            </a>
          </li>
        )
      }
      {
        hasPublications && (
          <li>
            <a
              href={`${baseUrl}#publications`}
              class="text-gray-700 hover:text-black transition-colors font-medium"
            >
              Publications
            </a>
          </li>
        )
      }
      {
        hasExperience && (
          <li>
            <a
              href={`${baseUrl}#experience`}
              class="text-gray-700 hover:text-black transition-colors font-medium"
            >
              Experience
            </a>
          </li>
        )
      }
      {
        hasEducation && (
          <li>
            <a
              href={`${baseUrl}#education`}
              class="text-gray-700 hover:text-black transition-colors font-medium"
            >
              Education
            </a>
          </li>
        )
      }
      {
        hasAwards && (
          <li>
            <a
              href={`${baseUrl}#awards`}
              class="text-gray-700 hover:text-black transition-colors font-medium"
            >
              Awards
            </a>
          </li>
        )
      }
      {
        hasCV && (
          <li>
            <a
              href={`${baseUrl}#cv`}
              class="text-gray-700 hover:text-black transition-colors font-medium"
            >
              CV
            </a>
          </li>
        )
      }
    </ul>
  </nav>
</header>

<script>
  window.addEventListener("scroll", () => {
    const header = document.getElementById("header");
    if (window.scrollY > 100) {
      header?.classList.add("bg-white/80", "backdrop-blur-sm");
    } else {
      header?.classList.remove("bg-white/80", "backdrop-blur-sm");
    }
  });
</script>

<style>
  html {
    scroll-behavior: smooth;
  }
</style>
