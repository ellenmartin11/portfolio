---
import { siteConfig } from "../config";
import Header from "../components/Header.astro";
import ProjectsGrid from "../components/ProjectsGrid.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";

const developmentProjects =
  siteConfig.projects?.filter((p) => p.category === "development") ?? [];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={siteConfig.description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;1,100;1,200;1,300;1,400;1,500;1,600;1,700&display=swap"
      rel="stylesheet"
    />
    <title>{siteConfig.name} - Data Science / Development</title>
  </head>
  <body>
    <Header />
    <section>
      <ProjectsGrid
        title="Data Science / Development Portfolio"
        indexPrefix="P"
        projects={developmentProjects}
      />
    </section>
    <Footer />
  </body>
</html>

